# Copy to .env and fill in values. Never commit .env.

DATABASE_URL=postgres://blurpadurp:dev@localhost:5432/blurpadurp

# Anthropic (used by src/ai/* stages)
ANTHROPIC_API_KEY=

# Voyage AI (embeddings for theme attach). 1024-dim voyage-3 matches pgvector schema.
VOYAGE_API_KEY=

# Google Cloud — the GDELT connector queries gdelt-bq.gdeltv2 on BigQuery.
# Service account needs BigQuery Data Viewer + Job User. Query costs are
# billed to GOOGLE_CLOUD_PROJECT; the free tier covers our volume.
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_PROJECT=

# Email delivery (Resend). Leave blank in dev to disable sending.
RESEND_API_KEY=
FROM_EMAIL=brief@blurpadurp.com

# Web push (VAPID). Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@blurpadurp.com
