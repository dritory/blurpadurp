{
  "name": "blurpadurp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "cli": "bun run src/cli.ts",
    "dev:api": "bun run --watch src/api/index.tsx",
    "migrate": "bun run src/cli.ts migrate",
    "test": "bun test",
    "build:admin": "bun build src/admin-client/*.ts --outdir=public/build --target=browser --minify",
    "dev:admin": "bun build src/admin-client/*.ts --outdir=public/build --target=browser --watch"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "latest",
    "@codemirror/lang-markdown": "^6.5.0",
    "@google-cloud/bigquery": "^8.1.1",
    "codemirror": "^6.0.2",
    "hono": "latest",
    "kysely": "latest",
    "pg": "latest",
    "resend": "latest",
    "rss-parser": "^3.13.0",
    "vis-network": "^10.0.2",
    "web-push": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "latest",
    "@types/web-push": "latest"
  }
}
