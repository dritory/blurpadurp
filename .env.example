# Copy to .env and fill in values. Never commit .env.

DATABASE_URL=postgres://blurpadurp:dev@localhost:5432/blurpadurp

# Public origin for absolute links in the Atom feed and magic-link emails.
# No trailing slash. Defaults to http://localhost:3000 when unset.
BLURPADURP_PUBLIC_URL=http://localhost:3000

# Secret for signing confirm / unsubscribe / preference magic-link tokens.
# Generate with: openssl rand -hex 32
# Changing this invalidates all outstanding links — avoid in production.
BLURPADURP_TOKEN_SECRET=

# Admin pages (/admin/*) are disabled unless ADMIN_PASSWORD is set.
# Basic-auth gate — username defaults to "admin" if ADMIN_USER unset.
ADMIN_USER=admin
ADMIN_PASSWORD=

# Set to 1 during stage-2 (hidden deploy) to serve a Disallow-all robots.txt.
# Leave blank in production to allow crawlers.
BLURPADURP_BLOCK_CRAWLERS=

# Anthropic (used by src/ai/* stages)
ANTHROPIC_API_KEY=

# Voyage AI (embeddings for theme attach). 1024-dim voyage-3 matches pgvector schema.
VOYAGE_API_KEY=

# Google Cloud — the GDELT connector queries gdelt-bq.gdeltv2 on BigQuery.
# Service account needs BigQuery Data Viewer + Job User. Query costs are
# billed to GOOGLE_CLOUD_PROJECT; the free tier covers our volume.
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_PROJECT=

# Email delivery (Resend). Leave blank in dev to disable sending.
RESEND_API_KEY=
FROM_EMAIL=brief@blurpadurp.com
# Resend webhook signing secret (whsec_... from the dashboard). Leave
# blank to disable the /webhooks/resend endpoint — it returns 503
# until set. Register the endpoint in Resend for email.bounced,
# email.complained (+ email.delivered optional, informational only).
RESEND_WEBHOOK_SECRET=

# Web push (VAPID). Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@blurpadurp.com
